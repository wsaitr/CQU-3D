# =============================================================================
# CQU3D 分离部署 — GPU 侧配置模板
# =============================================================================
# 使用方式： cp .env.gpu.example .env.gpu 然后修改必填项
# 通用配置项（任务队列、D2DGS 参数等）见项目根目录 .env.example
# 密钥和数据库密码必须与 CPU 侧的 .env.cpu 完全一致
# =============================================================================

# 【必须修改】共享存储在本 GPU 机器的挂载路径（与 CPU 侧指向同一份数据）
HOST_STORAGE_ROOT=/mnt/cqu3d_storage

# ----【必须修改】CPU 服务器的内网 IP ----
MYSQL_HOST=10.0.0.10
MYSQL_PORT=3306
MYSQL_DATABASE=repo_db
MYSQL_USER=repo_user
MYSQL_PASSWORD=please_replace_app_password
MYSQL_URL=
REDIS_URL=redis://10.0.0.10:6379/0

# ----【必须修改】安全密钥（必须与 CPU 侧 .env.cpu 完全一致）----
APP_NAME=cqu3d-async-platform
APP_VERSION=3.0-split
JWT_SECRET_KEY=please_replace_with_a_long_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
INTERNAL_API_TOKEN=please_replace_internal_token

# 容器内统一路径（不要改）
STORAGE_ROOT=/workspace/repo/storage
INPUT_DIR=/workspace/repo/storage/input
WORKSPACE_DIR=/workspace/repo/storage/workspace
OUTPUT_DIR=/workspace/repo/storage/output
LOG_DIR=/workspace/repo/storage/logs

# 队列参数（需与 CPU 侧保持一致）
TASK_INCOMING_QUEUE=cqu3d:tasks:incoming
TASK_READY_QUEUE=cqu3d:tasks:ready
TASK_HEARTBEAT_PREFIX=cqu3d:tasks:heartbeat
TASK_DISPATCH_LOCK_PREFIX=cqu3d:tasks:dispatch-lock
TASK_WORKER_LOCK_PREFIX=cqu3d:tasks:worker-lock
TASK_TIMEOUT=21600
TASK_HEARTBEAT_TIMEOUT=300
TASK_MAX_RETRIES=2

DISPATCHER_POLL_TIMEOUT=5
DISPATCHER_MONITOR_INTERVAL=15
DISPATCHER_MAX_INFLIGHT=2

WORKER_POLL_TIMEOUT=5
WORKER_CONCURRENCY=1
WORKER_ID=gpu-worker-01

# GPU 与 dynamic-2dgs 参数
DYNAMIC_2DGS_ROOT=/workspace/repo/services/dynamic-2dgs
GS_PYTHON=/usr/local/bin/python
COLMAP_BIN=colmap
FFMPEG_BIN=ffmpeg
DISABLE_GPU=false
CUDA_VISIBLE_DEVICES=0
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
TORCH_CUDA_ARCH_LIST=8.0;8.6;8.9

D2DGS_FRAME_FPS=3
D2DGS_MAX_FRAMES=120
D2DGS_MAX_WIDTH=1280
D2DGS_CAMERA_MODEL=OPENCV
D2DGS_COLMAP_USE_GPU=true
D2DGS_DEFORM_TYPE=static
D2DGS_ITERATIONS=2000
D2DGS_RESOLUTION=1
D2DGS_EVAL=true
D2DGS_LOAD2GPU_ON_THE_FLY=true
D2DGS_LOCAL_FRAME=false
D2DGS_GT_ALPHA_MASK_AS_SCENE_MASK=false
D2DGS_RENDER_MESH=true
D2DGS_RENDER_IMAGES=false
D2DGS_VOXEL_SIZE=0.004
D2DGS_DEPTH_TRUNC=6.0
D2DGS_NUM_CLUSTER=1000
D2DGS_UNBOUNDED_MESH=false
D2DGS_MESH_RES=1024

# 业务限制字段（worker 进程初始化会读取）
MAX_FILE_SIZE=4GB
MAX_PROJECT_SIZE=10GB
MAX_PROJECTS_PER_USER=5
MAX_GLOBAL_STORAGE=200GB
